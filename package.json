{
  "name": "@reify-ai/reify",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./kits/fs": {
      "types": "./dist/kits/fs/index.d.ts",
      "default": "./dist/kits/fs/index.js"
    },
    "./kits/github": {
      "types": "./dist/kits/github/index.d.ts",
      "default": "./dist/kits/github/index.js"
    }
  },
  "files": [
    "dist/"
  ],
  "scripts": {
    "build": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\" && tsc -p tsconfig.json",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@octokit/core": "^7.0.6",
    "arktype": "^2.1.29"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "^5.0.0"
  }
}
